# -*- coding: utf-8 -*-
"""
Patch script for backward_fall_walking.py
Applies 3 fixes:
  Fix 1: Slower, more natural walking (0.8 m/s, stand_height=1.3)
  Fix 2: Stop post-fall twitching (settled detection + zero action + gear freeze)
  Fix 3: Smoother walking transition (blend_steps 30 -> 60)
"""

import re, sys, shutil, os
from pathlib import Path

TARGET = Path(os.path.expanduser("~/mujoco_project/backward_fall_walking.py"))

if not TARGET.exists():
    sys.exit(f"ERROR: File not found: {TARGET}")

# Backup
backup = TARGET.with_suffix(".py.bak")
shutil.copy2(TARGET, backup)
print(f"  Backup saved to: {backup}")

src = TARGET.read_text()
original = src  # keep for diff reporting

changes = 0

# -----------------------------------------------------------------------
# FIX 1 - Replace infer_z_walk_stable body (slower speed + height)
# -----------------------------------------------------------------------
OLD_WALK = '''\
def infer_z_walk_stable(n_samples=1000):
    """
    Infer robust walking embedding using weighted regression
    as described in Meta Motivo paper (Sec 8.5.3)
    """
    print("  Inferring z_walk (stable locomotion)...")
    reward_fn = LocomotionReward(move_speed=1.2, move_angle=0, stand_height=1.4)'''

NEW_WALK = '''\
def infer_z_walk_stable(n_samples=1000):
    """
    Infer robust walking embedding using weighted regression
    SLOWER speed (0.8 m/s instead of 1.2 m/s) for natural walking
    """
    print("  Inferring z_walk (natural locomotion, slower speed)...")
    # REDUCED SPEED from 1.2 to 0.8 for natural walking
    reward_fn = LocomotionReward(move_speed=0.8, move_angle=0, stand_height=1.3)'''

if OLD_WALK in src:
    src = src.replace(OLD_WALK, NEW_WALK, 1)
    changes += 1
    print("  [Fix 1] ?  infer_z_walk_stable - speed 1.2?0.8, height 1.4?1.3")
else:
    print("  [Fix 1] ?  Could not find infer_z_walk_stable header - skipped")

# -----------------------------------------------------------------------
# FIX 2a - Add is_fallen + apply_zero_action methods before get_lie_down_reward
# -----------------------------------------------------------------------
OLD_LIE = '''\
    def get_lie_down_reward(self, orient=\'up\'):'''

NEW_METHODS = '''\
    def is_fallen(self, pelvis_height, velocity_threshold=0.1):
        """Check if humanoid has settled on ground"""
        return pelvis_height < 0.15 and abs(self.mj_data.cvel[1][0]) < velocity_threshold

    def apply_zero_action(self):
        """Apply zero action to stop movement"""
        return np.zeros(self.env.action_space.shape)

    def get_lie_down_reward(self, orient=\'up\'):'''

if OLD_LIE in src:
    src = src.replace(OLD_LIE, NEW_METHODS, 1)
    changes += 1
    print("  [Fix 2a] ?  Added is_fallen() and apply_zero_action() to BiofidelicFallController")
else:
    print("  [Fix 2a] ?  Could not find get_lie_down_reward anchor - skipped")

# -----------------------------------------------------------------------
# FIX 2b - Add fall_settled / settled_steps init before 'with mujoco.viewer'
# -----------------------------------------------------------------------
OLD_VIEWER = 'with mujoco.viewer.launch_passive(mj_model, mj_data) as viewer:'
NEW_VIEWER = ('# Fall-settling state\nfall_settled = False\nsettled_steps = 0\n\n'
              'with mujoco.viewer.launch_passive(mj_model, mj_data) as viewer:')

if OLD_VIEWER in src and 'fall_settled = False' not in src:
    src = src.replace(OLD_VIEWER, NEW_VIEWER, 1)
    changes += 1
    print("  [Fix 2b] ?  Inserted fall_settled / settled_steps before viewer launch")
elif 'fall_settled = False' in src:
    print("  [Fix 2b] -  fall_settled already present - skipped")
else:
    print("  [Fix 2b] ?  Could not find viewer launch anchor - skipped")

# -----------------------------------------------------------------------
# FIX 2c - Replace FALL phase logic (else: block)
# -----------------------------------------------------------------------
OLD_FALL = '''\
        else:  # FALL
            phase = \'fall\'
            if step == phase_boundaries[4]:
                print(f"  [Step {step}] Full collapse phase")
                controller.clear_forces()
                controller.finalize_z_transition()
            
            # Maintain severe weakness
            controller.update_muscle_weakening(1.0)'''

NEW_FALL = '''\
        else:  # FALL
            phase = \'fall\'
            if step == phase_boundaries[4]:
                print(f"  [Step {step}] Full collapse phase")
                controller.clear_forces()
                controller.finalize_z_transition()
                fall_settled = False
                settled_steps = 0

            # Check if settled
            pelvis_id = mujoco.mj_name2id(mj_model, MJOBJ_BODY, "Pelvis")
            pelvis_pos = mj_data.xpos[pelvis_id]
            pelvis_vel = mj_data.cvel[pelvis_id]

            if not fall_settled:
                if pelvis_pos[2] < 0.15 and abs(pelvis_vel[0]) < 0.1 and abs(pelvis_vel[2]) < 0.1:
                    settled_steps += 1
                    if settled_steps > 30:  # 1 second of stability
                        fall_settled = True
                        print(f"  [Step {step}] Fall settled - freezing motion")
                else:
                    settled_steps = 0

            if fall_settled:
                # STOP all movement - apply zero action and disable actuators
                action = controller.apply_zero_action()
                # Set all actuator gear to near-zero to prevent twitching
                for i in range(mj_model.nu):
                    mj_model.actuator_gear[i, 0] = controller.original_gear[i] * 0.01
            else:
                # Still falling - maintain severe weakness
                controller.update_muscle_weakening(1.0)'''

if OLD_FALL in src:
    src = src.replace(OLD_FALL, NEW_FALL, 1)
    changes += 1
    print("  [Fix 2c] ?  FALL phase logic replaced with settling detection")
else:
    print("  [Fix 2c] ?  Could not find FALL phase block - skipped")

# -----------------------------------------------------------------------
# FIX 3 - Smoother walking transition (blend_steps 30 -> 60)
# -----------------------------------------------------------------------
OLD_BLEND = '''\
                controller.set_target_z(z_walk, blend_steps=30)
                env.unwrapped.set_task("move-ego-0-2")
                print(f"  [Step {step}] Walking phase started")'''

NEW_BLEND = '''\
                controller.set_target_z(z_walk, blend_steps=60)  # INCREASED from 30 to 60
                env.unwrapped.set_task("move-ego-0-2")
                print(f"  [Step {step}] Walking phase started (slow transition)")'''

if OLD_BLEND in src:
    src = src.replace(OLD_BLEND, NEW_BLEND, 1)
    changes += 1
    print("  [Fix 3] ?  Walk blend_steps 30 ? 60 for smoother transition")
else:
    print("  [Fix 3] ?  Could not find walk blend_steps=30 line - skipped")

# -----------------------------------------------------------------------
# Write result
# -----------------------------------------------------------------------
if changes == 0:
    print("\n  No changes applied - file may already be patched or differ from expected.")
    sys.exit(0)

TARGET.write_text(src)
print(f"\n  Done - {changes}/5 patches applied successfully.")
print(f"  File written: {TARGET}")
print(f"  Original backup: {backup}")